From e16318852af1a583bfae7f1c0607a9d4edf8fccf Mon Sep 17 00:00:00 2001
From: Marek Vasut <marek.vasut+renesas@mailbox.org>
Date: Sat, 10 May 2025 17:41:01 +0200
Subject: [PATCH 4/4] arm64: dts: renesas: sparrow-hawk: Inhibit microSD UHS
 mode support

Disable UHS mode support on Retronix R-Car V4H Sparrow Hawk board
microSD slot.

The EVTA1 prototype board does not have U104 voltage switch populated
on the board, the U104 is instead bridged using a wire to always supply
3.3V to SDHI_D1.8V_D3.3V power rail. This prevents UHS modes from being
used on EVTA1 prototype board.

The U104 voltage switch will be populated on EVTB1 board revision,
this commit should be removed once EVTB1 board becomes available.

Signed-off-by: Marek Vasut <marek.vasut+renesas@mailbox.org>
---
 .../src/arm64/renesas/r8a779g3-sparrow-hawk.dts      | 12 +++---------
 1 file changed, 3 insertions(+), 9 deletions(-)

diff --git a/dts/upstream/src/arm64/renesas/r8a779g3-sparrow-hawk.dts b/dts/upstream/src/arm64/renesas/r8a779g3-sparrow-hawk.dts
index b109095a0d8..f58d1396e5f 100644
--- a/dts/upstream/src/arm64/renesas/r8a779g3-sparrow-hawk.dts
+++ b/dts/upstream/src/arm64/renesas/r8a779g3-sparrow-hawk.dts
@@ -135,13 +135,10 @@
 
 	/* Page 17 uSD-Slot */
 	vcc_sdhi: regulator-vcc-sdhi {
-		compatible = "regulator-gpio";
+		compatible = "regulator-fixed";
 		regulator-name = "SDHI VccQ";
-		regulator-min-microvolt = <1800000>;
+		regulator-min-microvolt = <3300000>;
 		regulator-max-microvolt = <3300000>;
-		gpios = <&gpio8 13 GPIO_ACTIVE_HIGH>;
-		gpios-states = <1>;
-		states = <3300000 0>, <1800000 1>;
 	};
 };
 
@@ -393,12 +390,9 @@
 /* Page 17 uSD-Slot */
 &mmc0 {
 	pinctrl-0 = <&sd_pins>;
-	pinctrl-1 = <&sd_uhs_pins>;
-	pinctrl-names = "default", "state_uhs";
+	pinctrl-names = "default";
 	bus-width = <4>;
 	cd-gpios = <&gpio3 11 GPIO_ACTIVE_LOW>;	/* SD_CD */
-	sd-uhs-sdr50;
-	sd-uhs-sdr104;
 	vmmc-supply = <&reg_3p3v>;
 	vqmmc-supply = <&vcc_sdhi>;
 	status = "okay";
-- 
