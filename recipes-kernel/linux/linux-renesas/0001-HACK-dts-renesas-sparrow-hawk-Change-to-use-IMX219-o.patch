From e558eda85453a13c7a07e5cb73adfd542823cfbb Mon Sep 17 00:00:00 2001
From: Yuya Hamamachi <yuya.hamamachi.sx@renesas.com>
Date: Tue, 24 Jun 2025 14:02:27 +0900
Subject: [PATCH] HACK: dts: renesas: sparrow-hawk: Change to use IMX219 on J2

Signed-off-by: Yuya Hamamachi <yuya.hamamachi.sx@renesas.com>
---
 .../dts/renesas/r8a779g3-sparrow-hawk.dts     | 20 +++++++++----------
 1 file changed, 10 insertions(+), 10 deletions(-)

diff --git a/arch/arm64/boot/dts/renesas/r8a779g3-sparrow-hawk.dts b/arch/arm64/boot/dts/renesas/r8a779g3-sparrow-hawk.dts
index 97a70224e73b..4fb359859594 100644
--- a/arch/arm64/boot/dts/renesas/r8a779g3-sparrow-hawk.dts
+++ b/arch/arm64/boot/dts/renesas/r8a779g3-sparrow-hawk.dts
@@ -517,26 +517,26 @@ &i2c2 {
 #if CAM_J2
 	status = "okay";
 
-	imx219_j2: imx462@1a {
-		compatible = "sony,imx462lqr";
-		reg = <0x1a>;
+	imx219_j2: imx219@10 {
+		compatible = "sony,imx219";
+		reg = <0x10>;
 		status = "okay";
 
 		clocks = <&clk_cam_j2>;
 		clock-names = "xclk";
-		clock-frequency = <37125000>;
 
-		vdddo-supply = <&reg_cam_j2>;
-		vdda-supply = <&reg_cam_j2_dummy>;
-		vddd-supply = <&reg_cam_j2_dummy>;
+		VANA-supply = <&reg_cam_j2>;
+		VDIG-supply = <&reg_cam_j2_dummy>;
+		VDDL-supply = <&reg_cam_j2_dummy>;
 
 		orientation = <2>;
 		rotation = <0>;
 
 		port {
 			rpicam_j2: endpoint {
-				link-frequencies = /bits/ 64 <222750000 148500000>;
-				data-lanes = <1 2 3 4>;
+				clock-noncontinuous;
+				link-frequencies = /bits/ 64 <456000000>;
+				data-lanes = <1 2>;
 				remote-endpoint = <&csi41_in>;
 			};
 		};
@@ -963,7 +963,7 @@ port@0 {
 			csi41_in: endpoint {
 				bus-type = <MEDIA_BUS_TYPE_CSI2_DPHY>;
 				clock-lanes = <0>;
-				data-lanes = <1 2 3 4>;
+				data-lanes = <1 2>;
 				remote-endpoint = <&rpicam_j2>;
 			};
 		};
-- 
2.34.1

