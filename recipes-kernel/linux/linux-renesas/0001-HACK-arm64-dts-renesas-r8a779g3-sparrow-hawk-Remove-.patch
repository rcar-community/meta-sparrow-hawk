From c3511ad0931bdca85399f5e0098539b4d441955e Mon Sep 17 00:00:00 2001
From: Yuya Hamamachi <yuya.hamamachi.sx@renesas.com>
Date: Fri, 27 Jun 2025 13:24:03 +0900
Subject: [PATCH] HACK: arm64: dts: renesas: r8a779g3: sparrow-hawk: Remove
 CAM_Jx define

If 2 CSI is enabled but 1 camera is connected, csi driver does not
finish initialization. Thus, these settings are removed by default to
enable each camera by devicetree overlay.

Signed-off-by: Yuya Hamamachi <yuya.hamamachi.sx@renesas.com>
---
 .../dts/renesas/r8a779g3-sparrow-hawk.dts     | 178 ------------------
 1 file changed, 178 deletions(-)

diff --git a/arch/arm64/boot/dts/renesas/r8a779g3-sparrow-hawk.dts b/arch/arm64/boot/dts/renesas/r8a779g3-sparrow-hawk.dts
index 67160f8ce67c..845f340ac316 100644
--- a/arch/arm64/boot/dts/renesas/r8a779g3-sparrow-hawk.dts
+++ b/arch/arm64/boot/dts/renesas/r8a779g3-sparrow-hawk.dts
@@ -33,12 +33,6 @@
 #include <dt-bindings/media/video-interfaces.h>
 #include <dt-bindings/thermal/thermal.h>
 
-/* Enable this if there is a camera module in J1. */
-#define CAM_J1 1
-
-/* Enable this if there is a camera module in J2. */
-#define CAM_J2 1
-
 #include "r8a779g3.dtsi"
 
 / {
@@ -479,34 +473,6 @@ &i2c1 {
 	#size-cells = <0>;
 	pinctrl-0 = <&i2c1_pins>;
 	pinctrl-names = "default";
-#if CAM_J1
-	status = "okay";
-
-	imx219_j1: imx219@10 {
-		compatible = "sony,imx219";
-		reg = <0x10>;
-		status = "okay";
-
-		clocks = <&clk_cam_j1>;
-		clock-names = "xclk";
-
-		VANA-supply = <&reg_cam_j1>;
-		VDIG-supply = <&reg_cam_j1_dummy>;
-		VDDL-supply = <&reg_cam_j1_dummy>;
-
-		orientation = <2>;
-		rotation = <0>;
-
-		port {
-			rpicam_j1: endpoint {
-				clock-noncontinuous;
-				link-frequencies = /bits/ 64 <456000000>;
-				data-lanes = <1 2>;
-				remote-endpoint = <&csi40_in>;
-			};
-		};
-	};
-#endif
 };
 
 /* Page 29 / CSI_IF_CN / CAM_CN1 */
@@ -515,34 +481,6 @@ &i2c2 {
 	#size-cells = <0>;
 	pinctrl-0 = <&i2c2_pins>;
 	pinctrl-names = "default";
-#if CAM_J2
-	status = "okay";
-
-	imx219_j2: imx462@1a {
-		compatible = "sony,imx462lqr";
-		reg = <0x1a>;
-		status = "okay";
-
-		clocks = <&clk_cam_j2>;
-		clock-names = "xclk";
-		clock-frequency = <37125000>;
-
-		vdddo-supply = <&reg_cam_j2>;
-		vdda-supply = <&reg_cam_j2_dummy>;
-		vddd-supply = <&reg_cam_j2_dummy>;
-
-		orientation = <2>;
-		rotation = <0>;
-
-		port {
-			rpicam_j2: endpoint {
-				link-frequencies = /bits/ 64 <222750000 148500000>;
-				data-lanes = <1 2 3 4>;
-				remote-endpoint = <&csi41_in>;
-			};
-		};
-	};
-#endif
 };
 
 /* Page 31 / IO_CN */
@@ -1026,119 +964,3 @@ &sensor_thermal_ddr1 {
 	critical-action = "shutdown";
 };
 
-#if CAM_J1
-/* Page 29 / CSI_IF_CN */
-&csi40 {
-	status = "okay";
-
-	ports {
-		#address-cells = <1>;
-		#size-cells = <0>;
-
-		port@0 {
-			reg = <0>;
-
-			csi40_in: endpoint {
-				bus-type = <MEDIA_BUS_TYPE_CSI2_DPHY>;
-				clock-lanes = <0>;
-				data-lanes = <1 2>;
-				remote-endpoint = <&rpicam_j1>;
-			};
-		};
-	};
-};
-
-&isp0 {
-	status = "okay";
-};
-
-&vin00 {
-	status = "okay";
-};
-
-&vin01 {
-        status = "okay";
-};
-
-&vin02 {
-        status = "okay";
-};
-
-&vin03 {
-        status = "okay";
-};
-
-&vin04 {
-        status = "okay";
-};
-
-&vin05 {
-        status = "okay";
-};
-
-&vin06 {
-        status = "okay";
-};
-
-&vin07 {
-	status = "okay";
-};
-#endif
-
-#if CAM_J2
-/* Page 29 / CSI_IF_CN */
-&csi41 {
-	status = "okay";
-
-	ports {
-		#address-cells = <1>;
-		#size-cells = <0>;
-
-		port@0 {
-			reg = <0>;
-
-			csi41_in: endpoint {
-				bus-type = <MEDIA_BUS_TYPE_CSI2_DPHY>;
-				clock-lanes = <0>;
-				data-lanes = <1 2 3 4>;
-				remote-endpoint = <&rpicam_j2>;
-			};
-		};
-	};
-};
-&isp1 {
-	status = "okay";
-};
-
-&vin08 {
-	status = "okay";
-};
-
-&vin09 {
-	status = "okay";
-};
-
-&vin10 {
-	status = "okay";
-};
-
-&vin11 {
-	status = "okay";
-};
-
-&vin12 {
-	status = "okay";
-};
-
-&vin13 {
-	status = "okay";
-};
-
-&vin14 {
-	status = "okay";
-};
-
-&vin15 {
-	status = "okay";
-};
-#endif
-- 
2.34.1

